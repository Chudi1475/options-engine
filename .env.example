# telegram alerts
# 1) make a bot: message @BotFather in telegram, /newbot, copy the token
# 2) both people message the new bot anything (/start)
# 3) run: python scanner.py --setup   -> prints chat ids
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=

# account dollar size, used for the $ amounts on cards.
# easier: text /setaccount 25000 to the bot (that overrides this).
ACCOUNT_VALUE=

# practice mode: every card gets a [PAPER] tag, nothing changes otherwise
PAPER_MODE=false

# optional: real-time stock data (free paper account at alpaca.markets ->
# dashboard -> API keys). SPX always stays on yfinance (alpaca has no index data).
ALPACA_API_KEY=
ALPACA_API_SECRET=

# optional but big: an Anthropic API key (console.anthropic.com, pay per use)
# powers TWO things: (1) the morning web-search news check, and (2) the bot's
# brain — text it anything, send chart screenshots or files, get real answers.
ANTHROPIC_API_KEY=
# BOT_BRAIN_MODEL=claude-sonnet-4-6   # model the chat brain uses

# optional overrides (defaults live in config.py)
# MIN_WINRATE=70
# TP_HALF_PCT=25
# STOP_PCT=-30
# RISK_PER_TRADE_PCT=1.0
# DATA_DIR=/data        # cloud: point at the mounted volume
